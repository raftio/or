# API (apps/api)
# With Docker Postgres (see scripts/setup-postgres-docker.sh):
DATABASE_URL=postgresql://orca:orca@localhost:5432/orca
# Or your own Postgres:
# DATABASE_URL=postgresql://user:password@localhost:5432/orca
JWT_SECRET=your-secret-at-least-16-chars

# pgvector DB for code indexing (see scripts/setup-postgres-docker.sh):
VECTOR_DATABASE_URL=postgresql://orca:orca@localhost:5434/orca_vectors

# OpenAI API key — required for code search (embedding + semantic search)
OPENAI_API_KEY=

# Web (apps/web) – optional; defaults to http://localhost:3001
# NEXT_PUBLIC_API_URL=http://localhost:3001
