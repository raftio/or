{
  "name": "orca",
  "version": "0.1.0",
  "private": true,
  "description": "Orca Control Plane – intent to execution to evidence to outcome",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @orca/api run dev",
    "dev:api": "pnpm --filter @orca/api run dev",
    "dev:web": "pnpm --filter @orca/web run dev",
    "dev:worker": "pnpm --filter @orca/worker run dev",
    "start": "pnpm --filter @orca/api run start",
    "lint": "eslint \"apps/**/*.ts\" \"apps/**/*.tsx\" \"packages/**/*.ts\" \"packages/**/*.tsx\"",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
