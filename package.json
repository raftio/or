{
  "name": "orqestra",
  "version": "0.1.0",
  "description": "Orqestra Control Plane - intent to execution to evidence to outcome",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:api": "turbo run dev --filter=@orqestra/api",
    "dev:web": "turbo run dev --filter=@orqestra/web",
    "start": "turbo run start --filter=@orqestra/api",
    "lint": "turbo run lint",
    "format": "prettier --write \"{apps,packages}/**/*.{ts,tsx,js,json}\"",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  }
}
